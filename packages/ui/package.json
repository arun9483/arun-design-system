{
  "name": "@arun-dev/ui",
  "version": "0.1.0",
  "description": "Brand-agnostic React component library styled entirely via @arun-dev/tokens semantic CSS custom properties",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arun9483/arun-design-system.git",
    "directory": "packages/ui"
  },
  "keywords": [
    "react",
    "components",
    "design-system",
    "css-custom-properties"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./components.css": "./dist/css/components.css",
    "./css/reset": "./dist/css/reset.css",
    "./css/btn": "./dist/css/btn.css",
    "./css/card": "./dist/css/card.css",
    "./css/chip": "./dist/css/chip.css",
    "./css/badge": "./dist/css/badge.css",
    "./css/metric": "./dist/css/metric.css",
    "./css/utilities": "./dist/css/utilities.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run --passWithNoTests --config vitest.unit.config.ts"
  },
  "dependencies": {
    "@arun-dev/tokens": "workspace:*"
  },
  "devDependencies": {
    "@arun-dev/config": "workspace:*",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "eslint": "9.39.4",
    "jsdom": "29.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "3.2.6"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  }
}
